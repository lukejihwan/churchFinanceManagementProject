PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=church_finance

# 인증 (로그인 필수)
JWT_SECRET=긴_무작위_문자열로_변경
JWT_EXPIRES_IN=7d

# CORS — 프론트 개발 서버 주소 (예: Vite 기본)
FRONTEND_ORIGIN=http://localhost:5173

# 영수증 업로드 (선택)
# UPLOAD_DIR=./uploads/receipts
# UPLOAD_MAX_BYTES=5242880

# 관리자 계정 생성 스크립트용 (npm run create-admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=8자이상비밀번호
# ADMIN_NAME=관리자
